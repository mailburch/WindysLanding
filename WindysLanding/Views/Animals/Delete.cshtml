@model WindysLanding.Models.Animal

@{
    ViewData["Title"] = "Delete Animal";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this animal?</h3>
<div>
    <h4>@Model.Name</h4>
    <hr />

    @if (Model.Photos != null && Model.Photos.Any())
    {
        <img src="@Model.Photos.First().ImgUrl" alt="@Model.Name" style="max-width:200px;" />
    }

    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Type</dt>
        <dd class="col-sm-9">@Model.AnimalType</dd>

        <dt class="col-sm-3">Age</dt>
        <dd class="col-sm-9">@(Model.Age.HasValue? Model.Age + " years" : "Unknown")</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@(Model.AdoptionStatus ? "Adopted" : "Available")</dd>

        @if (Model.Photos != null && Model.Photos.Any())
        {
            <dt class="col-sm-3">Photos</dt>
            <dd class="col-sm-9">@Model.Photos.Count() photo(s) will be deleted</dd>
        }
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="AnimalId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Cancel</a>
    </form>
</div>
