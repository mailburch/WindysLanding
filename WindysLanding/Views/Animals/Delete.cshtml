@model WindysLanding.Models.Animal

@{
    ViewData["Title"] = "Delete Animal";
}

<div class="animals-page container py-4">

    <section class="page-hero text-center">
        <h1 class="page-title">Delete Animal</h1>
        <p class="page-subtitle">Review the details below before removing this animal.</p>
    </section>

    <section class="content-panel animal-delete-warning mb-4">
        <h2 class="section-title mb-2">Are you sure you want to delete this animal?</h2>
        <p class="mb-0">This will remove the animal profile and any associated photos.</p>
    </section>

    <div class="animal-detail-layout">
        <section class="content-panel">
            <h2 class="section-title mb-4">@Model.Name</h2>

            <dl class="animal-details-list mb-0">
                <div class="animal-details-row">
                    <dt>Name</dt>
                    <dd>@Model.Name</dd>
                </div>
                <div class="animal-details-row">
                    <dt>Type</dt>
                    <dd>@Model.AnimalType</dd>
                </div>
                <div class="animal-details-row">
                    <dt>Age</dt>
                    <dd>@(Model.Age.HasValue? Model.Age + " years" : "Unknown")</dd>
                </div>
                <div class="animal-details-row">
                    <dt>Status</dt>
                    <dd>@(Model.AdoptionStatus ? "Adopted" : "Available")</dd>
                </div>
                @if (Model.Photos != null && Model.Photos.Any())
                {
                    <div class="animal-details-row">
                        <dt>Photos</dt>
                        <dd>@Model.Photos.Count() photo(s) will be deleted</dd>
                    </div>
                }
            </dl>
        </section>

        <section class="content-panel">
            <h2 class="section-title mb-4">Photo</h2>
            @if (Model.Photos != null && Model.Photos.Any())
            {
                <div class="animal-preview-box">
                    <img src="@Model.Photos.First().ImgUrl" alt="@Model.Name" class="animal-detail-img" />
                </div>
            }
            else
            {
                <div class="animal-no-photo">
                    <img src="/images/placeholder-animal.jpg" alt="No photo" class="animal-card-img" />
                    <p class="mb-0 mt-2">No photo uploaded</p>
                </div>
            }
        </section>
    </div>

    <form asp-action="Delete" class="mt-4 d-flex flex-wrap gap-2">
        <input type="hidden" asp-for="AnimalId" />
        <button type="submit" class="btn btn-outline-danger">Delete Animal</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>

</div>