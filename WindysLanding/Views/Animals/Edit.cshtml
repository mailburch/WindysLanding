@model WindysLanding.Models.Animal

@{
    ViewData["Title"] = "Edit Animal";
}

<div class="animals-page container py-4">

    <section class="page-hero text-center">
        <h1 class="page-title">Edit @Model.Name</h1>
        <p class="page-subtitle">Update animal information, photos, and adoption details.</p>
    </section>

    <div class="animal-edit-layout">
        <section class="content-panel">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="AnimalId" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="AnimalType" class="form-label"></label>
                        <input asp-for="AnimalType" class="form-control" />
                        <span asp-validation-for="AnimalType" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Age" class="form-label"></label>
                        <input asp-for="Age" class="form-control" />
                        <span asp-validation-for="Age" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Gender" class="form-label"></label>
                        <input asp-for="Gender" class="form-control" />
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Breed" class="form-label"></label>
                        <input asp-for="Breed" class="form-control" />
                        <span asp-validation-for="Breed" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Size" class="form-label"></label>
                        <input asp-for="Size" class="form-control" />
                        <span asp-validation-for="Size" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Color" class="form-label"></label>
                        <input asp-for="Color" class="form-control" />
                        <span asp-validation-for="Color" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Experience" class="form-label"></label>
                    <textarea asp-for="Experience" class="form-control"></textarea>
                    <span asp-validation-for="Experience" class="text-danger"></span>
                </div>

                <div class="form-check mb-2">
                    <input class="form-check-input" asp-for="AdoptionStatus" />
                    <label class="form-check-label" asp-for="AdoptionStatus">Mark as Adopted</label>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="SponsorshipAvailable" />
                    <label class="form-check-label" asp-for="SponsorshipAvailable">Available for Sponsorship</label>
                </div>

                <div class="mb-4">
                    <label asp-for="SponsorshipUrl" class="form-label"></label>
                    <input asp-for="SponsorshipUrl" class="form-control" />
                    <span asp-validation-for="SponsorshipUrl" class="text-danger"></span>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </section>

        <section class="content-panel">
            @if (Model.Photos != null && Model.Photos.Any())
            {
                var carouselId = "edit-carousel";
                <div id="@carouselId" class="carousel slide mb-3" data-bs-ride="false">
                    <div class="carousel-inner">
                        @{
                            var photoIndex = 0;
                            foreach (var photo in Model.Photos)
                            {
                                var activeClass = photoIndex == 0 ? "active" : "";
                                <div class="carousel-item @activeClass">
                                    <img src="@photo.ImgUrl" class="animal-card-img" alt="@Model.Name">
                                </div>
                                photoIndex++;
                            }
                        }
                    </div>

                    @if (Model.Photos.Count() > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>

                        <div class="carousel-indicators">
                            @for (var i = 0; i < Model.Photos.Count(); i++)
                            {
                                var activeIndicator = i == 0 ? "active" : "";
                                <button type="button" data-bs-target="#@carouselId" data-bs-slide-to="@i" class="@activeIndicator" aria-current="@(i == 0 ? "true" : "false")"></button>
                            }
                        </div>
                    }
                </div>

                <h5 class="section-title mb-3">Manage Photos</h5>
                <div class="animal-photo-list mb-4">
                    @foreach (var photo in Model.Photos)
                    {
                        <div class="animal-photo-row">
                            <img src="@photo.ImgUrl" alt="@Model.Name" class="animal-thumb" />
                            <form asp-action="DeletePhoto" asp-route-id="@photo.PhotoId" method="post" class="flex-grow-1">
                                <button type="submit" class="btn btn-outline-danger btn-sm w-100" onclick="return confirm('Delete this photo?');">Delete</button>
                            </form>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="animal-no-photo mb-4">
                    <img src="/images/placeholder-animal.jpg" alt="No photos" class="animal-card-img" />
                    <p class="mb-0 mt-2">No photos yet</p>
                </div>
            }

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="AnimalId" />
                <input type="hidden" asp-for="Name" />
                <input type="hidden" asp-for="AnimalType" />
                <input type="hidden" asp-for="Age" />
                <input type="hidden" asp-for="Size" />
                <input type="hidden" asp-for="Description" />
                <input type="hidden" asp-for="Gender" />
                <input type="hidden" asp-for="Breed" />
                <input type="hidden" asp-for="Color" />
                <input type="hidden" asp-for="Experience" />
                <input type="hidden" asp-for="AdoptionStatus" />
                <input type="hidden" asp-for="SponsorshipAvailable" />
                <input type="hidden" asp-for="SponsorshipUrl" />

                <div class="card">
                    <div class="card-header">Add New Photos</div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Upload Photos</label>
                            <input type="file" name="photos" multiple accept="image/*" class="form-control" required />
                            <small class="text-muted">Select one or more photos</small>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Upload Photos</button>
                    </div>
                </div>
            </form>
        </section>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}