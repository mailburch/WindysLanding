@model IEnumerable<WindysLanding.Models.Animal>
@{
    ViewData["Title"] = "Animals";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Our Animals</h1>
    <a asp-action="Create" class="btn btn-primary">Add New Animal</a>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        var carouselId = "carousel-" + item.AnimalId;
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                @if (item.Photos != null && item.Photos.Any())
                {
                    <!-- Carousel for multiple photos -->
                    <div id="@carouselId" class="carousel slide" data-bs-ride="false">
                        <div class="carousel-inner">
                            @{
                                var photoIndex = 0;
                                foreach (var photo in item.Photos)
                                {
                                    var activeClass = photoIndex == 0 ? "active" : "";
                                    <div class="carousel-item @activeClass">
                                        <img src="@photo.ImgUrl" class="d-block w-100" alt="@photo.Caption" style="height: 250px; object-fit: cover;">
                                        @if (!string.IsNullOrEmpty(photo.Caption))
                                        {
                                            <div class="carousel-caption d-none d-md-block" style="background-color: rgba(0,0,0,0.6); border-radius: 5px;">
                                                <p class="mb-0">@photo.Caption</p>
                                            </div>
                                        }
                                    </div>
                                    photoIndex++;
                                }
                            }
                        </div>

                        @if (item.Photos.Count() > 1)
                        {
                            <!-- Carousel controls (only show if more than 1 photo) -->
                            <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Previous</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Next</span>
                            </button>

                            <!-- Indicators -->
                            <div class="carousel-indicators">
                                @for (var i = 0; i < item.Photos.Count(); i++)
                                {
                                    var activeIndicator = i == 0 ? "active" : "";
                                    <button type="button" data-bs-target="#@carouselId" data-bs-slide-to="@i" class="@activeIndicator" aria-current="@(i == 0 ? "true" : "false")" aria-label="Slide @(i + 1)"></button>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 250px;">
                        <span class="text-white">No Photo</span>
                    </div>
                }

                <div class="card-body">
                    <h5 class="card-title">@item.Name</h5>
                    <p class="card-text">
                        <strong>Type:</strong> @item.AnimalType<br />
                        <strong>Age:</strong> @(item.Age.HasValue? item.Age + " years" : "Unknown")<br />
                        <strong>Breed:</strong> @(item.Breed ?? "Mixed")<br />
                        <strong>Gender:</strong> @item.Gender<br />
                        <strong>Status:</strong>
                        @if (item.AdoptionStatus)
                        {
                            <span class="badge bg-success">Adopted</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">Available</span>
                        }
                    </p>
                    @if (!string.IsNullOrEmpty(item.Description))
                    {
                        <p class="card-text">
                            <small>@(item.Description.Length > 100 ? item.Description.Substring(0, 100) + "..." : item.Description)</small>
                        </p>
                    }
                </div>
                <div class="card-footer">
                    <div class="btn-group w-100" role="group">
                        <a asp-action="Details" asp-route-id="@item.AnimalId" class="btn btn-sm btn-outline-primary">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.AnimalId" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.AnimalId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <p>No animals found. <a asp-action="Create">Add your first animal</a></p>
    </div>
}
