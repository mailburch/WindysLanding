@model IEnumerable<WindysLanding.Models.Animal>
@{
    ViewData["Title"] = "Animals";
}

<div class="animals-page container py-4">

    <section class="page-hero">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h1 class="page-title mb-2">Manage Animals</h1>
                <p class="page-subtitle mb-0">View, filter, and manage animal profiles.</p>
            </div>
            <div>
                <a asp-action="Create" class="btn btn-primary">Add New Animal</a>
            </div>
        </div>
    </section>

    <section class="content-panel mb-4">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Search</label>
                <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Name or breed..." />
            </div>
            <div class="col-md-3">
                <label class="form-label">Type</label>
                <select name="animalType" class="form-select">
                    <option value="">All Types</option>
                    @foreach (var type in ViewBag.AnimalTypes as List<string>)
                    {
                        <option value="@type" selected="@(ViewBag.AnimalType == type)">@type</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="adoptionStatus" class="form-select">
                    <option value="">All</option>
                    <option value="false" selected="@(ViewBag.AdoptionStatus == false)">Available</option>
                    <option value="true" selected="@(ViewBag.AdoptionStatus == true)">Adopted</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </section>

    @if (Model.Any())
    {
        <div class="animal-grid">
            @foreach (var item in Model)
            {
                var carouselId = "carousel-" + item.AnimalId;
                <div class="card animal-manage-card">
                    @if (item.Photos != null && item.Photos.Any())
                    {
                        <div id="@carouselId" class="carousel slide" data-bs-ride="false">
                            <div class="carousel-inner">
                                @{
                                    var photoIndex = 0;
                                    foreach (var photo in item.Photos)
                                    {
                                        var activeClass = photoIndex == 0 ? "active" : "";
                                        <div class="carousel-item @activeClass">
                                            <img src="@photo.ImgUrl" class="animal-card-img" alt="@photo.Caption">
                                            @if (!string.IsNullOrEmpty(photo.Caption))
                                            {
                                                <div class="carousel-caption d-none d-md-block">
                                                    <p class="mb-0">@photo.Caption</p>
                                                </div>
                                            }
                                        </div>
                                        photoIndex++;
                                    }
                                }
                            </div>

                            @if (item.Photos.Count() > 1)
                            {
                                <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Previous</span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Next</span>
                                </button>

                                <div class="carousel-indicators">
                                    @for (var i = 0; i < item.Photos.Count(); i++)
                                    {
                                        var activeIndicator = i == 0 ? "active" : "";
                                        <button type="button" data-bs-target="#@carouselId" data-bs-slide-to="@i" class="@activeIndicator" aria-current="@(i == 0 ? "true" : "false")"></button>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <img src="/images/placeholder-animal.jpg" class="animal-card-img" alt="No photo">
                    }

                    <div class="card-body">
                        <h5 class="card-title animal-name">@item.Name</h5>
                        <p class="card-text animal-meta">
                            <strong>Type:</strong> @item.AnimalType<br />
                            <strong>Age:</strong> @(item.Age.HasValue? item.Age + " years" : "Unknown")<br />
                            @if (!string.IsNullOrEmpty(item.Breed))
                            {
                                <span><strong>Breed:</strong> @item.Breed<br /></span>
                            }
                            @if (!string.IsNullOrEmpty(item.Gender))
                            {
                                <span><strong>Gender:</strong> @item.Gender<br /></span>
                            }
                            <strong>Status:</strong>
                            @if (item.AdoptionStatus)
                            {
                                <span class="badge bg-success">Adopted</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Available</span>
                            }
                        </p>

                        @if (!string.IsNullOrEmpty(item.Description))
                        {
                            <p class="card-text animal-description mb-0">
                                <small>@(item.Description.Length > 100 ? item.Description.Substring(0, 100) + "..." : item.Description)</small>
                            </p>
                        }
                    </div>

                    <div class="card-footer">
                        <div class="btn-group w-100" role="group">
                            <a asp-action="Details" asp-route-id="@item.AnimalId" class="btn btn-sm btn-outline-primary">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.AnimalId" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.AnimalId" class="btn btn-sm btn-outline-danger">Delete</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <p class="mb-0">No animals found. <a asp-action="Create">Add your first animal</a></p>
        </div>
    }

</div>