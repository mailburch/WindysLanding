@{
    ViewData["Title"] = "Donate";
}

<div class="donations-page container py-4">

    <section class="page-hero text-center">
        <h1 class="page-title">Donate &amp; Save a Life</h1>
        <p class="page-subtitle">
            Your donation helps us provide food, shelter, and veterinary care for animals in need.
        </p>
    </section>

    <section class="content-panel mb-4">
        <h2 class="section-title text-center mb-4">Where Your Donation Goes</h2>

        <div class="donation-grid">
            <div class="card donation-card">
                <div class="card-body text-center">
                    <img src="~/images/feed-and-care.jpg" alt="Feed and Care" class="donation-icon" />
                    <h3 class="h5 mt-3 mb-2">Feed &amp; Care</h3>
                    <p class="mb-0">Helps provide daily food, supplements, and routine care for rescued animals.</p>
                </div>
            </div>

            <div class="card donation-card">
                <div class="card-body text-center">
                    <img src="~/images/veterinary-care.png" alt="Veterinary Care" class="donation-icon" />
                    <h3 class="h5 mt-3 mb-2">Veterinary Care</h3>
                    <p class="mb-0">Covers exams, medications, emergency treatment, and ongoing medical support.</p>
                </div>
            </div>

            <div class="card donation-card">
                <div class="card-body text-center">
                    <img src="~/images/shelter-facilities.png" alt="Shelter and Facilities" class="donation-icon" />
                    <h3 class="h5 mt-3 mb-2">Shelter &amp; Facilities</h3>
                    <p class="mb-0">Supports safe housing, maintenance, fencing, bedding, and rescue property needs.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="content-panel mb-4">
        <h2 class="section-title text-center mb-4">How to Donate</h2>

        <div class="donation-highlight text-center mb-4">
            <h3 class="h5 mb-2">Zeffy (Preferred - No fees!)</h3>
            <p class="mb-3">Your full donation goes further to help animals in need.</p>
            <a class="btn btn-primary"
               href="https://www.zeffy.com/en-US/donation-form/donate-to-save-slaughter-bound-horses"
               target="_blank" rel="noopener noreferrer">
                Donate via Zeffy
            </a>
        </div>

        <div class="donation-method-grid">
            <div class="card">
                <div class="card-body">
                    <h3 class="h5 mb-3">PayPal / Venmo</h3>
                    <p>
                        PayPal: donate&#64;windyslanding.org<br />
                        Venmo: &#64;WindysLanding
                    </p>
                    @* TODO: Replace # with real PayPal link *@
                    <a class="btn btn-outline-primary" href="#" target="_blank" rel="noopener noreferrer">
                        Donate via PayPal
                    </a>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h3 class="h5 mb-3">Mail a Check</h3>
                    <address class="mb-0 donation-address">
                        Windy's Landing Animal Rescue<br />
                        669 N Lake Leelanau Drive<br />
                        Lake Leelanau, MI 49653
                    </address>
                </div>
            </div>
        </div>
    </section>

    <section class="content-panel text-center">
        <h2 class="section-title mb-4">Other Ways to Help</h2>

        <ul class="donation-links">
            @* TODO: Replace # with real Amazon Wishlist link *@
            <li><a href="#" target="_blank" rel="noopener noreferrer">Amazon Wishlist</a></li>

            @* TODO: Replace # with real Chewy Wishlist link *@
            <li><a href="#" target="_blank" rel="noopener noreferrer">Chewy Wishlist</a></li>

            <li><a asp-controller="VolunteerApplications" asp-action="Create">Volunteer Your Time</a></li>

            <li>
                <a href="https://www.zeffy.com/en-US/donation-form/donate-to-save-slaughter-bound-horses"
                   target="_blank" rel="noopener noreferrer">
                    Share Our Mission
                </a>
            </li>
        </ul>

        @* TODO: Update once wishlist links are confirmed *@
        <a class="btn btn-outline-secondary" href="#" target="_blank" rel="noopener noreferrer">
            View Wishlists
        </a>
    </section>

</div>