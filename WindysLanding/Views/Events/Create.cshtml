@model WindysLanding.Models.Event

@{
    ViewData["Title"] = "Create Event";
}

@* TODO: This page should only be accessible to Admin users once authentication is implemented *@

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="text-center mb-4">
            <h1>Create Event</h1>
            <h4 class="text-muted">Add a new event</h4>
        </div>

        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Date" class="form-label"></label>
                <input asp-for="Date" type="datetime-local" class="form-control" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EventUrl" class="form-label"></label>
                <input asp-for="EventUrl" class="form-control" />
                <span asp-validation-for="EventUrl" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label for="ImageFile" class="form-label">Upload Photo</label>
                <input type="file" name="ImageFile" id="ImageFile" class="form-control" accept="image/*" onchange="previewImage(event)" />
                <div class="form-text">Choose an image for this event. This image will also be saved to the Photos library.</div>
                <span class="text-danger">@Html.ValidationMessage("ImageFile")</span>
            </div>

            <div class="mb-3 text-center">
                <label class="form-label d-block">Photo Preview</label>
                <div id="imagePreviewContainer" class="border rounded p-2 bg-light d-flex align-items-center justify-content-center" style="height:250px;">
                    <span id="previewPlaceholder" class="text-muted">No photo selected</span>
                    <img id="imagePreview"
                         src="#"
                         alt="Image Preview"
                         class="img-fluid d-none"
                         style="max-height:100%; max-width:100%; object-fit:contain;" />
                </div>
            </div>

            <div class="d-flex justify-content-center gap-2 mt-4">
                <input type="submit" value="Create Event" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function previewImage(event) {
            const input = event.target;
            const preview = document.getElementById('imagePreview');
            const placeholder = document.getElementById('previewPlaceholder');

            if (input.files && input.files[0]) {
                const reader = new FileReader();

                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.classList.remove('d-none');
                    placeholder.classList.add('d-none');
                };

                reader.readAsDataURL(input.files[0]);
            } else {
                preview.src = '#';
                preview.classList.add('d-none');
                placeholder.classList.remove('d-none');
            }
        }
    </script>
}