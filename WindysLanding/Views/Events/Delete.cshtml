@model WindysLanding.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

        <div class="text-center mb-4">
            <h1>Delete Event</h1>
            <h4 class="text-danger">Are you sure you want to delete this event?</h4>
        </div>

        <div class="card">

            <div class="card-body">

                <div class="mb-3 text-center">
                    <label class="form-label d-block">Event Photo</label>

                    @if (!string.IsNullOrEmpty(Model.EventImg))
                    {
                        <div class="bg-light border rounded d-flex align-items-center justify-content-center p-2" style="height:250px;">
                            <img src="@Model.EventImg"
                                 alt="@Model.Name"
                                 class="img-fluid"
                                 style="max-height:100%; max-width:100%; object-fit:contain;" />
                        </div>
                    }
                    else
                    {
                        <div class="border rounded p-4 text-muted bg-light">
                            No photo available
                        </div>
                    }
                </div>

                <dl class="row">

                    <dt class="col-sm-4">
                        Event Name
                    </dt>
                    <dd class="col-sm-8">
                        @Model.Name
                    </dd>

                    <dt class="col-sm-4">
                        Description
                    </dt>
                    <dd class="col-sm-8">
                        @Model.Description
                    </dd>

                    <dt class="col-sm-4">
                        Date
                    </dt>
                    <dd class="col-sm-8">
                        @Model.Date.ToString("MMMM d, yyyy h:mm tt")
                    </dd>

                    <dt class="col-sm-4">
                        Event URL
                    </dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(Model.EventUrl))
                        {
                            <a href="@Model.EventUrl" target="_blank">@Model.EventUrl</a>
                        }
                        else
                        {
                            <span class="text-muted">None</span>
                        }
                    </dd>

                </dl>

            </div>

            <div class="card-footer text-center">

                <form asp-action="Delete">
                    <input type="hidden" asp-for="EventId" />

                    <button type="submit" class="btn btn-danger">
                        Delete Event
                    </button>

                    <a asp-action="Index"
                       asp-route-id="@Model.EventId"
                       class="btn btn-outline-secondary">
                        Cancel
                    </a>

                </form>

            </div>

        </div>

    </div>
</div>