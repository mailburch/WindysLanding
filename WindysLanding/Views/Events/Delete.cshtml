@model WindysLanding.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<div class="events-page">
    <section class="page-hero text-center">
        <h1 class="page-title">Delete Event</h1>
        <p class="page-subtitle text-danger">
            Are you sure you want to delete this event? This action cannot be undone.
        </p>
    </section>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card p-4 p-md-5">
                <div class="row g-4 align-items-stretch">
                    <div class="col-md-5">
                        @if (!string.IsNullOrEmpty(Model.EventImg))
                        {
                            <img src="@Model.EventImg"
                                 alt="@Model.Name"
                                 class="event-detail-img" />
                        }
                        else
                        {
                            <div class="empty-state h-100 d-flex align-items-center justify-content-center">
                                <span>No Photo Available</span>
                            </div>
                        }
                    </div>

                    <div class="col-md-7 d-flex flex-column">
                        <div class="card-body px-0 py-0 d-flex flex-column h-100">
                            <span class="event-date-badge">
                                @Model.Date.ToString("MMMM d, yyyy")
                            </span>

                            <h3 class="event-title">@Model.Name</h3>

                            <p class="event-meta mb-3">
                                <strong>Time:</strong> @Model.Date.ToString("h:mm tt")
                            </p>

                            <div class="content-panel mb-3">
                                <h4 class="section-title h6 mb-2">Description</h4>
                                @if (!string.IsNullOrEmpty(Model.Description))
                                {
                                    <p class="event-description mb-0">@Model.Description</p>
                                }
                                else
                                {
                                    <p class="mb-0 text-muted">No description provided.</p>
                                }
                            </div>

                            <div class="content-panel mb-4">
                                <h4 class="section-title h6 mb-2">Event Link</h4>
                                @if (!string.IsNullOrEmpty(Model.EventUrl))
                                {
                                    <a href="@Model.EventUrl" target="_blank">@Model.EventUrl</a>
                                }
                                else
                                {
                                    <span class="text-muted">None</span>
                                }
                            </div>

                            <form asp-action="Delete" class="mt-auto">
                                <input type="hidden" asp-for="EventId" />

                                <div class="d-flex justify-content-center justify-content-md-start gap-2 flex-wrap">
                                    <button type="submit" class="btn btn-outline-danger">
                                        Delete Event
                                    </button>

                                    <a asp-action="Details"
                                       asp-route-id="@Model.EventId"
                                       class="btn btn-outline-primary">
                                        Back to Details
                                    </a>

                                    <a asp-action="Index"
                                       class="btn btn-outline-secondary">
                                        Cancel
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>