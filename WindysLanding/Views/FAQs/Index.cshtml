@model IEnumerable<WindysLanding.Models.FAQ>

@{
    ViewData["Title"] = "FAQs";
    string? currentCategory = ViewData["CurrentCategory"] as string;
    string? currentSearch = ViewData["CurrentSearch"] as string;
    var categories = ViewData["Categories"] as List<string> ?? new List<string>();
}

<h1>FREQUENTLY ASKED QUESTIONS</h1>

<hr />

<!-- Search Bar -->
<form method="get" asp-action="Index">
    <input type="hidden" name="category" value="@currentCategory" />
    <input type="text"
           name="search"
           value="@currentSearch"
           placeholder="Search FAQs..." />
    <button type="submit">Search</button>
</form>

<!-- Category Filter Tabs -->
<div>
    <a asp-action="Index"
       asp-route-search="@currentSearch"
       asp-route-category="">
        [All]
    </a>

    @foreach (var cat in categories)
    {
        <a asp-action="Index"
           asp-route-search="@currentSearch"
           asp-route-category="@cat">
            [@cat]
        </a>
    }
</div>

<!-- FAQ Accordion -->
@if (!Model.Any())
{
    <p>No FAQs found.</p>
}
else
{
    @foreach (var faq in Model)
    {
        <details>
            <summary>@faq.Question</summary>
            <div>
                <p>@faq.Answer</p>
            </div>
        </details>
        <hr />
    }
}

<!-- Didn't find your answer -->
<div>
    <strong>Didn't find your answer?</strong>
    <p>We're here to help! Contact us via email for fastest response.</p>
    <a asp-controller="Home" asp-action="Contact">Contact Us</a>
</div>
