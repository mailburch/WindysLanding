@model WindysLanding.Models.ContactPageViewModel

@{
    ViewData["Title"] = "Contact";
    var contact = ViewBag.ContactInfo as WindysLanding.Models.ContactInfo;
}

<section class="page-hero text-center">
    <div class="container">
        <h1 class="page-title">Contact Us</h1>
        <p class="page-subtitle">
            Questions about adoption, volunteering, donations, or sponsorship? We’d love to hear from you.
        </p>
    </div>
</section>

<div class="container py-4">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success text-center shadow-sm">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-4">

            <div class="card border-0 shadow-sm contact-side-card mb-4">
                <div class="card-body p-4">
                    <h2 class="section-title h4 mb-3">Contact Information</h2>

                    <div class="contact-info-item">
                        <div class="contact-label">Phone</div>
                        <div>@(string.IsNullOrWhiteSpace(contact?.Phone) ? "Not available" : contact.Phone)</div>
                    </div>

                    <div class="contact-info-item">
                        <div class="contact-label">Email</div>
                        <div>@(string.IsNullOrWhiteSpace(contact?.Email) ? "Not available" : contact.Email)</div>
                    </div>

                    <div class="contact-info-item mb-0">
                        <div class="contact-label">Address</div>
                        <div>@(string.IsNullOrWhiteSpace(contact?.Address) ? "Not available" : contact.Address)</div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm contact-side-card">
                <div class="card-body p-4">
                    <h2 class="section-title h4 mb-2">Newsletter Sign Up</h2>
                    <p class="text-muted mb-3">
                        Get rescue updates, event announcements, and adoption success stories.
                    </p>

                    @if (TempData["NewsletterSuccess"] != null)
                    {
                        <div class="alert alert-success">
                            @TempData["NewsletterSuccess"]
                        </div>
                    }

                    @if (TempData["NewsletterError"] != null)
                    {
                        <div class="alert alert-danger">
                            @TempData["NewsletterError"]
                        </div>
                    }

                    <form asp-controller="Home" asp-action="NewsletterSignup" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="NewsletterSignup.Email" class="form-label"></label>
                            <input asp-for="NewsletterSignup.Email" class="form-control" placeholder="you@example.com" />
                            <span asp-validation-for="NewsletterSignup.Email" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-outline-primary w-100">
                            Sign Up
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm contact-form-card">
                <div class="card-body p-4 p-lg-5">
                    <div class="mb-4">
                        <h2 class="section-title mb-2">Send Us a Message</h2>
                        <p class="text-muted mb-0">
                            Fill out the form below and someone from our team will get back to you soon.
                        </p>
                    </div>

                    <form asp-controller="Home" asp-action="Contact" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="ContactForm.Name" class="form-label"></label>
                                <input asp-for="ContactForm.Name" class="form-control" />
                                <span asp-validation-for="ContactForm.Name" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ContactForm.Phone" class="form-label"></label>
                                <input asp-for="ContactForm.Phone" class="form-control" />
                                <span asp-validation-for="ContactForm.Phone" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ContactForm.Email" class="form-label"></label>
                                <input asp-for="ContactForm.Email" class="form-control" />
                                <span asp-validation-for="ContactForm.Email" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ContactForm.Subject" class="form-label"></label>
                                <input asp-for="ContactForm.Subject" class="form-control" />
                                <span asp-validation-for="ContactForm.Subject" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="ContactForm.Message" class="form-label"></label>
                                <textarea asp-for="ContactForm.Message" class="form-control" rows="7"></textarea>
                                <span asp-validation-for="ContactForm.Message" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary px-4">
                                Send Message
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}