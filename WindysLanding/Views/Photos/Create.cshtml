@model WindysLanding.Models.Photo
@{
    ViewData["Title"] = "Add Photo";
}

<h1>Add Photo</h1>
<hr />

<div class="alert alert-info">
    <strong>Note:</strong> Select only ONE option below - the photo can belong to either an Animal, Sponsor Company, Newsletter, or Event. Leave the others blank.
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <h5 class="mt-3">Photo For (Choose One):</h5>

            <div class="form-group">
                <label asp-for="AnimalId" class="control-label"></label>
                <select asp-for="AnimalId" class="form-control" asp-items="ViewBag.AnimalId">
                    <option value="">-- Select Animal (Optional) --</option>
                </select>
                <small class="form-text text-muted">Choose an animal if this is an animal photo</small>
            </div>

            <div class="form-group">
                <label asp-for="SponsorCompanyId" class="control-label"></label>
                <select asp-for="SponsorCompanyId" class="form-control" asp-items="ViewBag.SponsorCompanyId">
                    <option value="">-- Select Sponsor (Optional) --</option>
                </select>
                <small class="form-text text-muted">Choose a company if this is a sponsor logo</small>
            </div>

            <div class="form-group">
                <label asp-for="NewsletterId" class="control-label"></label>
                <select asp-for="NewsletterId" class="form-control" asp-items="ViewBag.NewsletterId">
                    <option value="">-- Select Newsletter (Optional) --</option>
                </select>
                <small class="form-text text-muted">Choose a newsletter if this is newsletter related</small>
            </div>

            <div class="form-group">
                <label asp-for="EventId" class="control-label"></label>
                <select asp-for="EventId" class="form-control" asp-items="ViewBag.EventId">
                    <option value="">-- Select Event (Optional) --</option>
                </select>
                <small class="form-text text-muted">Choose an event if this is an event flyer</small>
            </div>

            <hr />
            <h5>Upload Photo:</h5>

            <div class="form-group">
                <label for="ImageFile" class="control-label">Choose Image File</label>
                <input type="file" id="ImageFile" name="ImageFile" class="form-control" accept="image/*" />
                <small class="form-text text-muted">
                    Upload an image file (JPG, PNG, GIF, WEBP). Max size: 10MB.
                </small>
            </div>

            <div class="text-center my-3">
                <strong>- OR -</strong>
            </div>

            <div class="form-group">
                <label asp-for="ImgUrl" class="control-label">Or Enter Image URL</label>
                <input asp-for="ImgUrl" class="form-control" />
                <span asp-validation-for="ImgUrl" class="text-danger"></span>
                <small class="form-text text-muted">
                    If you prefer, paste a URL to an online image instead of uploading
                </small>
            </div>

            <div class="form-group">
                <label asp-for="Caption" class="control-label"></label>
                <input asp-for="Caption" class="form-control" placeholder="Optional description of the photo" />
                <span asp-validation-for="Caption" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Add Photo" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <strong>How to Add Photos</strong>
            </div>
            <div class="card-body">
                <h6>Method 1: Upload a File (Recommended)</h6>
                <ul>
                    <li>Click "Choose Image File"</li>
                    <li>Select an image from your computer</li>
                    <li>Image will be automatically uploaded and saved</li>
                </ul>

                <h6>Method 2: Use an Online Image</h6>
                <ul>
                    <li>Find an image online</li>
                    <li>Copy its full URL</li>
                    <li>Paste into the "Image URL" field</li>
                </ul>

                <h6>Image Requirements:</h6>
                <ul>
                    <li>Recommended size: 800x600 pixels or larger</li>
                    <li>Formats: JPG, PNG, GIF, WEBP</li>
                    <li>Maximum file size: 10MB</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
