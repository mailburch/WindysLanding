@model WindysLanding.Models.SponsorCompany

@{
    ViewData["Title"] = "Add Sponsor";
}

<div class="sponsors-page container py-4">

    <section class="page-hero text-center">
        <h1 class="page-title">Add New Sponsor</h1>
        <p class="page-subtitle">
            Add a sponsor logo and company details to feature them on the site.
        </p>
    </section>

    <section class="content-panel sponsor-form-panel">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Company Name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description"
                          class="form-control"
                          rows="4"
                          placeholder="Optional description or website URL..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="card sponsor-upload-card mb-4">
                <div class="card-header">
                    Logo
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="logoInput" class="form-label">Upload Logo</label>
                        <input type="file" name="logo" accept="image/*" class="form-control" id="logoInput" />
                        <div class="form-text">
                            Upload company logo (PNG or JPG recommended, max 5MB).
                        </div>
                    </div>

                    <div id="logoPreview" class="sponsor-logo-preview-empty"></div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary">Add Sponsor</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </section>

</div>

<script>
    document.getElementById('logoInput').addEventListener('change', function (e) {
        const preview = document.getElementById('logoPreview');
        preview.innerHTML = '';
        preview.className = '';

        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();

            reader.onload = function (event) {
                preview.className = 'sponsor-logo-preview';
                preview.innerHTML = `
                    <img src="${event.target.result}" alt="Logo preview" class="sponsor-logo-preview-img" />
                    <p class="sponsor-logo-file-name">${file.name}</p>
                `;
            };

            reader.readAsDataURL(file);
        } else {
            preview.className = 'sponsor-logo-preview-empty';
        }
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}