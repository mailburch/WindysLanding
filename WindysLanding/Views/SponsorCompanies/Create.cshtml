@model WindysLanding.Models.SponsorCompany

@{
    ViewData["Title"] = "Add Sponsor";
}

<h1>Add New Sponsor</h1>

<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Company Name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Optional description or website URL..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <hr />

            <h4>Logo</h4>
            <div class="card mb-3">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label"><strong>Upload Logo</strong></label>
                        <input type="file" name="logo" accept="image/*" class="form-control" id="logoInput" />
                        <small class="text-muted">Upload company logo (PNG or JPG recommended, max 5MB)</small>
                    </div>

                    <div id="logoPreview"></div>
                </div>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary btn-lg">Add Sponsor</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script>
    // Logo preview
    document.getElementById('logoInput').addEventListener('change', function(e) {
        const preview = document.getElementById('logoPreview');
        preview.innerHTML = '';

        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();

            reader.onload = function(e) {
                preview.innerHTML = `
                    <div class="text-center border p-3">
                        <img src="${e.target.result}" class="img-fluid" style="max-height: 200px; object-fit: contain;" />
                        <p class="mt-2 mb-0"><small>${file.name}</small></p>
                    </div>
                `;
            }

            reader.readAsDataURL(file);
        }
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
