@model WindysLanding.Models.SponsorCompany

@{
    ViewData["Title"] = "Delete Sponsor";
}

<h1>Delete Sponsor</h1>

<h3>Are you sure you want to delete this sponsor?</h3>

<div class="card">
    <div class="card-body">
        <div class="row">
            <div class="col-md-4 text-center">
                @if (Model.Photos != null && Model.Photos.Any())
                {
                    <img src="@Model.Photos.First().ImgUrl" alt="@Model.Name" class="img-fluid border p-3" style="max-height: 200px; object-fit: contain;" />
                }
                else
                {
                    <img src="/images/placeholder-logo.png" alt="No logo" class="img-fluid" style="max-height: 200px;" />
                }
            </div>
            <div class="col-md-8">
                <dl class="row">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@Model.Description</dd>
                    }
                </dl>
            </div>
        </div>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="SponsorCompanyId" />
    <button type="submit" class="btn btn-danger">Delete Sponsor</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
