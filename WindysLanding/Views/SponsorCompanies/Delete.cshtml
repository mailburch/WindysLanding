@model WindysLanding.Models.SponsorCompany

@{
    ViewData["Title"] = "Delete Sponsor";
}

<div class="sponsors-page container py-4">

    <section class="page-hero text-center">
        <h1 class="page-title">Delete Sponsor</h1>
        <p class="page-subtitle">
            Review the sponsor details below before permanently removing them.
        </p>
    </section>

    <section class="content-panel sponsor-delete-warning mb-4">
        <h2 class="section-title mb-2">Are you sure you want to delete this sponsor?</h2>
        <p class="mb-0">
            This will remove the sponsor information and associated logo from the site.
        </p>
    </section>

    <div class="sponsor-edit-layout">

        <section class="content-panel sponsor-form-panel">
            <h2 class="section-title mb-4">@Model.Name</h2>

            <dl class="sponsor-details-list mb-0">
                <div class="sponsor-details-row">
                    <dt>Name</dt>
                    <dd>@Model.Name</dd>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div class="sponsor-details-row">
                        <dt>Description</dt>
                        <dd>@Model.Description</dd>
                    </div>
                }
            </dl>
        </section>

        <section class="content-panel">
            <h2 class="section-title mb-4">Logo</h2>

            @if (Model.Photos != null && Model.Photos.Any())
            {
                <div class="sponsor-current-logo">
                    <img src="@Model.Photos.First().ImgUrl"
                         alt="@Model.Name"
                         class="sponsor-logo-preview-img" />
                </div>
            }
            else
            {
                <div class="sponsor-no-logo">
                    <img src="/images/placeholder-logo.png"
                         alt="No logo"
                         class="sponsor-logo-preview-img" />
                    <p class="mb-0">No logo uploaded</p>
                </div>
            }
        </section>

    </div>

    <form asp-action="Delete" class="mt-4 d-flex flex-wrap gap-2">
        <input type="hidden" asp-for="SponsorCompanyId" />
        <button type="submit" class="btn btn-outline-danger">Delete Sponsor</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>

</div>