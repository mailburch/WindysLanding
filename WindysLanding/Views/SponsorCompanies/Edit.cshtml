@model WindysLanding.Models.SponsorCompany

@{
    ViewData["Title"] = "Edit Sponsor";
}

<h1>Edit: @Model.Name</h1>

<hr />

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header">
                <h4 class="mb-0">Sponsor Information</h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="SponsorCompanyId" />

                    <div class="form-group mb-3">
                        <label asp-for="Name" class="control-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Description" class="control-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Optional description or website URL..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header">
                <h4 class="mb-0">Logo</h4>
            </div>
            <div class="card-body">
                @if (Model.Photos != null && Model.Photos.Any())
                {
                    var logo = Model.Photos.First();
                    <div class="text-center mb-3">
                        <img src="@logo.ImgUrl" alt="@Model.Name" class="img-fluid border p-2" style="max-height: 200px; object-fit: contain;" />
                    </div>
                    <form asp-action="DeleteLogo" asp-route-id="@logo.PhotoId" method="post">
                        <button type="submit" class="btn btn-danger w-100" onclick="return confirm('Delete this logo?');">Delete Logo</button>
                    </form>
                    <hr />
                }
                else
                {
                    <div class="text-center py-4">
                        <img src="/images/placeholder-logo.png" alt="No logo" class="img-fluid mb-2" style="max-height: 150px;" />
                        <p class="text-muted">No logo uploaded</p>
                    </div>
                }

                <!-- Upload New Logo -->
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="SponsorCompanyId" />
                    <input type="hidden" asp-for="Name" />
                    <input type="hidden" asp-for="Description" />

                    <div class="mb-3">
                        <label class="form-label"><strong>@(Model.Photos.Any() ? "Replace Logo" : "Upload Logo")</strong></label>
                        <input type="file" name="logo" accept="image/*" class="form-control" id="logoInput" required />
                        <small class="text-muted">PNG or JPG, max 5MB</small>
                    </div>

                    <div id="logoPreview" class="mb-3"></div>

                    <button type="submit" class="btn btn-success w-100">Upload Logo</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('logoInput').addEventListener('change', function(e) {
        const preview = document.getElementById('logoPreview');
        preview.innerHTML = '';

        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.innerHTML = `
                    <div class="text-center border p-2">
                        <img src="${e.target.result}" class="img-fluid" style="max-height: 150px; object-fit: contain;" />
                    </div>
                `;
            }
            reader.readAsDataURL(file);
        }
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
