@model IEnumerable<WindysLanding.Models.SponsorCompany>

@{
    ViewData["Title"] = "Manage Sponsors";
}

<div class="sponsors-page container py-4">

    <section class="page-hero">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h1 class="page-title mb-2">Manage Sponsors</h1>
                <p class="page-subtitle mb-0">
                    Add, review, and manage sponsor information shown on the site.
                </p>
            </div>

            <div>
                <a asp-action="Create" class="btn btn-primary">Add New Sponsor</a>
            </div>
        </div>
    </section>

    @if (Model.Any())
    {
        <section class="content-panel">
            <div class="sponsor-grid sponsor-manage-grid">
                @foreach (var sponsor in Model)
                {
                    <div class="card sponsor-card sponsor-manage-card">
                        <div class="card-body text-center">
                            @if (sponsor.Photos != null && sponsor.Photos.Any())
                            {
                                <img src="@sponsor.Photos.First().ImgUrl"
                                     alt="@sponsor.Name"
                                     class="sponsor-logo" />
                            }
                            else
                            {
                                <img src="/images/placeholder-logo.png"
                                     alt="No logo available"
                                     class="sponsor-logo" />
                            }

                            <h2 class="h5 sponsor-name">@sponsor.Name</h2>

                            @if (!string.IsNullOrWhiteSpace(sponsor.Description))
                            {
                                <p class="sponsor-description sponsor-description-trim mb-0">
                                    @(sponsor.Description.Length > 100
                                                            ? sponsor.Description.Substring(0, 100) + "..."
                                                            : sponsor.Description)
                                </p>
                            }
                        </div>

                        <div class="card-footer sponsor-card-footer">
                            <div class="d-flex gap-2">
                                <a asp-action="Edit"
                                   asp-route-id="@sponsor.SponsorCompanyId"
                                   class="btn btn-outline-secondary flex-fill">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@sponsor.SponsorCompanyId"
                                   class="btn btn-outline-danger flex-fill">
                                    Delete
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
    else
    {
        <section class="empty-state">
            <h2 class="h4 mb-3">No sponsors yet</h2>
            <p class="mb-3">Add your first sponsor to start building the sponsor page.</p>
            <a asp-action="Create" class="btn btn-primary">Add Sponsor</a>
        </section>
    }

</div>