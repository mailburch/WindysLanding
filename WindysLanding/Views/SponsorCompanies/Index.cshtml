@model IEnumerable<WindysLanding.Models.SponsorCompany>
@{
    ViewData["Title"] = "Manage Sponsors";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Manage Sponsors</h1>
    <a asp-action="Create" class="btn btn-primary">Add New Sponsor</a>
</div>

<div class="row">
    @foreach (var sponsor in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                @if (sponsor.Photos != null && sponsor.Photos.Any())
                {
                    <img src="@sponsor.Photos.First().ImgUrl" class="card-img-top" alt="@sponsor.Name" style="height: 200px; object-fit: contain; padding: 20px; background: #f8f9fa;" />
                }
                else
                {
                    <img src="/images/placeholder-logo.png" class="card-img-top" alt="No logo" style="height: 200px; object-fit: contain; padding: 20px; background: #f8f9fa;" />
                }

                <div class="card-body">
                    <h5 class="card-title">@sponsor.Name</h5>

                    @if (!string.IsNullOrEmpty(sponsor.Description))
                    {
                        <p class="card-text">
                            <small>@(sponsor.Description.Length > 100 ? sponsor.Description.Substring(0, 100) + "..." : sponsor.Description)</small>
                        </p>
                    }
                </div>

                <div class="card-footer">
                    <div class="btn-group w-100" role="group">
                        <a asp-action="Edit" asp-route-id="@sponsor.SponsorCompanyId" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@sponsor.SponsorCompanyId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <p>No sponsors yet. <a asp-action="Create">Add your first sponsor</a></p>
    </div>
}
