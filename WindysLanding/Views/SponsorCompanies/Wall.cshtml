@model IEnumerable<WindysLanding.Models.SponsorCompany>
@{
    ViewData["Title"] = "Our Sponsors";
}

<div class="text-center mb-5">
    <h1>Our Sponsors</h1>
    <p class="lead">Thank you to our amazing sponsors who make our work possible!</p>
</div>

@if (Model.Any())
{
    <div class="row">
        @foreach (var sponsor in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                <div class="card h-100 text-center">
                    <div class="card-body d-flex flex-column justify-content-center">
                        @if (sponsor.Photos != null && sponsor.Photos.Any())
                        {
                            <img src="@sponsor.Photos.First().ImgUrl" alt="@sponsor.Name" class="img-fluid mb-3" style="max-height: 120px; object-fit: contain;" />
                        }
                        else
                        {
                            <img src="/images/placeholder-logo.png" alt="@sponsor.Name" class="img-fluid mb-3" style="max-height: 120px; object-fit: contain;" />
                        }
                        <h5 class="card-title">@sponsor.Name</h5>
                        @if (!string.IsNullOrEmpty(sponsor.Description))
                        {
                            <p class="card-text"><small class="text-muted">@sponsor.Description</small></p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info text-center">
        <p>We're currently looking for sponsors. Interested in supporting us?</p>
    </div>
}

<!-- Become a Sponsor Section -->
<div class="card mt-5">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Become a Sponsor</h4>
    </div>
    <div class="card-body">
        <p>Your business can make a real difference! By sponsoring Windy's Landing Animal Rescue, you'll help us continue our mission while gaining visibility in the community.</p>

        <h5>Sponsorship Benefits:</h5>
        <ul>
            <li>Logo featured on our website</li>
            <li>Recognition on social media</li>
            <li>Support a great cause in the community</li>
        </ul>

        <p class="mb-0">
            <strong>Interested?</strong> Contact us to learn more about sponsorship opportunities:<br />
            Email: <a href="mailto:contact@windyslanding.org">contact@windyslanding.org</a><br />
            Phone: (231) 555-1234
        </p>
    </div>
</div>
