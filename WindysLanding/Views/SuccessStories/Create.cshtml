@model WindysLanding.Models.SuccessStory

@{
    ViewData["Title"] = "Create Success Story";
}

<div class="container mt-4">

    <h2>Create Success Story</h2>

    <hr />

    <form asp-action="Create" method="post" enctype="multipart/form-data">

        <div class="row">

            <div class="col-md-6">

                <div class="form-group mb-3">
                    <label asp-for="Title" class="control-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="AnimalId"></label>
                    <select asp-for="AnimalId"
                            class="form-control"
                            asp-items="ViewBag.AnimalId">
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="DatePublished"></label>
                    <input asp-for="DatePublished"
                           type="date"
                           class="form-control" />
                </div>

            </div>

            <div class="col-md-6">

                <div class="form-group mb-3">
                    <label class="control-label">Photos</label>
                    <input type="file" name="photos" multiple accept="image/*" class="form-control" id="photoInput" />
                    <small class="text-muted">Select one or more photos</small>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Content"></label>
                    <textarea asp-for="Content"
                              rows="6"
                              class="form-control"></textarea>
                </div>

            </div>

        </div>

        <button type="submit" class="btn btn-primary">
            Save Story
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
