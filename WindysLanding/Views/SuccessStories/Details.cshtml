@model WindysLanding.Models.SuccessStory

@{
    ViewData["Title"] = Model.Title;
    var imageUrl = (Model.Photos != null && Model.Photos.Any())
        ? Model.Photos.First().ImgUrl
        : Url.Content("~/images/placeholder-animal.jpg");
}

<div class="container py-4">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">← Back to Stories</a>

        <p class="story-meta mb-2">Adopted @Model.DatePublished.ToString("MMMM yyyy")</p>
        <h1 class="page-title text-start mb-2">@Model.Title</h1>
        <p class="text-muted mb-0">
            <strong>Animal:</strong> @Model.Animal?.AnimalType
        </p>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        @if (Model.Photos != null && Model.Photos.Count() > 1)
        {
            <!-- Photo Carousel for multiple photos -->
            var carouselId = "story-carousel";
            <div id="@carouselId" class="carousel slide" data-bs-ride="false">
                <div class="carousel-inner">
                    @{
                        var index = 0;
                        foreach (var photo in Model.Photos)
                        {
                            var active = index == 0 ? "active" : "";
                            <div class="carousel-item @active">
                                <img src="@photo.ImgUrl" class="d-block w-100 story-detail-img" alt="@Model.Title" />
                            </div>
                            index++;
                        }
                    }
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        }
        else
        {
            <!-- Single photo or placeholder -->
            <img src="@imageUrl"
                 class="story-detail-img"
                 alt="@Model.Title" />
        }

        <div class="card-body p-4 p-lg-5">
            <div class="story-full-content">
                @Model.Content
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2 flex-wrap">
        <a asp-action="Edit" asp-route-id="@Model.StoryId" class="btn btn-primary">Edit Story</a>
        <a asp-action="Index" class="btn btn-secondary">Back to Stories</a>
    </div>
</div>
