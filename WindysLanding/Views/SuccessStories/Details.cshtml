@model WindysLanding.Models.SuccessStory

<div class="container mt-4">

    <h2>@Model.Title</h2>

    <p class="text-muted">
        Adopted: @Model.DatePublished.ToString("MMMM yyyy")
    </p>

    <div class="row mt-4">

        <div class="col-md-4">

            <img src="~/images/@Model.PhotoId"
                 class="img-fluid rounded"
                 alt="@Model.Title" />

        </div>

        <div class="col-md-8">

            <p>
                <strong>Animal:</strong>
                @Model.Animal?.AnimalType
            </p>

            <p>
                @Model.Content
            </p>

        </div>

    </div>

    <hr />

    <a asp-action="Edit"
       asp-route-id="@Model.StoryId"
       class="btn btn-primary">
        Edit Story
    </a>

    <a asp-action="Index"
       class="btn btn-secondary">
        Back to Stories
    </a>

</div>