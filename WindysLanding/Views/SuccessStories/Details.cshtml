@model WindysLanding.Models.SuccessStory

@{
    ViewData["Title"] = Model.Title;
    var imageUrl = !string.IsNullOrWhiteSpace(Model.Photo?.ImgUrl)
        ? Model.Photo.ImgUrl
        : Url.Content("~/images/placeholder-animal.jpg");
}

<div class="container py-4">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">← Back to Stories</a>

        <p class="story-meta mb-2">Adopted @Model.DatePublished.ToString("MMMM yyyy")</p>
        <h1 class="page-title text-start mb-2">@Model.Title</h1>
        <p class="text-muted mb-0">
            <strong>Animal:</strong> @Model.Animal?.AnimalType
        </p>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <img src="@imageUrl"
             class="story-detail-img"
             alt="@Model.Title" />

        <div class="card-body p-4 p-lg-5">
            <div class="story-full-content">
                @Model.Content
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2 flex-wrap">
        <a asp-action="Edit" asp-route-id="@Model.StoryId" class="btn btn-primary">Edit Story</a>
        <a asp-action="Index" class="btn btn-secondary">Back to Stories</a>
    </div>
</div>