@model WindysLanding.Models.SuccessStory

<div class="container mt-4">

    <h2>Edit Success Story</h2>

    <hr />

    <div class="row">

        <div class="col-md-8">
            <form asp-action="Edit">

                <input type="hidden" asp-for="StoryId" />

                <div class="row">

                    <div class="col-md-6">

                        <div class="form-group mb-3">
                            <label asp-for="Title"></label>
                            <input asp-for="Title" class="form-control" />
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="AnimalId"></label>
                            <select asp-for="AnimalId"
                                    asp-items="ViewBag.AnimalId"
                                    class="form-control">
                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="DatePublished"></label>
                            <input asp-for="DatePublished"
                                   type="date"
                                   class="form-control" />
                        </div>

                    </div>

                    <div class="col-md-6">

                        <div class="form-group mb-3">
                            <label asp-for="Content"></label>
                            <textarea asp-for="Content"
                                      rows="6"
                                      class="form-control"></textarea>
                        </div>

                    </div>

                </div>

                <button type="submit" class="btn btn-success">
                    Save Changes
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Cancel
                </a>

            </form>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5>Photos</h5>
                </div>
                <div class="card-body">
                    @if (Model.Photos != null && Model.Photos.Any())
                    {
                        @foreach (var photo in Model.Photos)
                        {
                            <div class="mb-2 d-flex align-items-center border p-2">
                                <img src="@photo.ImgUrl" alt="Photo" style="width:60px; height:60px; object-fit:cover; margin-right:10px;" />
                                <form asp-action="DeletePhoto" asp-route-id="@photo.PhotoId" method="post" class="flex-grow-1">
                                    <button type="submit" class="btn btn-danger btn-sm w-100" onclick="return confirm('Delete this photo?');">Delete</button>
                                </form>
                            </div>
                        }
                        <hr />
                    }

                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="StoryId" />
                        <input type="hidden" asp-for="AnimalId" />
                        <input type="hidden" asp-for="Title" />
                        <input type="hidden" asp-for="Content" />
                        <input type="hidden" asp-for="DatePublished" />

                        <div class="mb-3">
                            <label class="form-label">Add Photos</label>
                            <input type="file" name="photos" multiple accept="image/*" class="form-control" required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Upload</button>
                    </form>
                </div>
            </div>
        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
