@model WindysLanding.Models.SuccessStory

<div class="container mt-4">

    <h2>Edit Success Story</h2>

    <hr />

    <form asp-action="Edit">

        <input type="hidden" asp-for="StoryId" />

        <div class="row">

            <div class="col-md-6">

                <div class="form-group mb-3">
                    <label asp-for="Title"></label>
                    <input asp-for="Title" class="form-control" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="AnimalId"></label>
                    <select asp-for="AnimalId"
                            asp-items="ViewBag.AnimalId"
                            class="form-control">
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="DatePublished"></label>
                    <input asp-for="DatePublished"
                           type="date"
                           class="form-control" />
                </div>

            </div>

            <div class="col-md-6">

                <div class="form-group mb-3">
                    <label asp-for="PhotoId"></label>
                    <input asp-for="PhotoId"
                           class="form-control" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Content"></label>
<textarea asp-for="Content"
          rows="6"
          class="form-control"></textarea>
                </div>

            </div>

        </div>

        <button type="submit" class="btn btn-success">
            Save Changes
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>