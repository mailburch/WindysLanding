@model IEnumerable<WindysLanding.Models.SuccessStory>

@{
    ViewData["Title"] = "Success Stories";
}

<style>
    /* Make long text wrap properly */
    .story-content {
        word-wrap: break-word;
        overflow-wrap: break-word;
        white-space: normal;
    }

    /* Optional: clamp preview to 3 lines for uniform height */
    .story-content.clamp {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<h2 class="text-center mt-4">SUCCESS STORIES</h2>
<p class="text-center">See the happy endings we've helped create</p>

<div class="container mt-4">

    <p>
        <a asp-action="Create" class="btn btn-primary mb-3">Create New Story</a>
    </p>

    @foreach (var item in Model)
    {
        <div class="row border rounded p-3 mb-4 align-items-center">

            <!-- Story Image -->
            <div class="col-md-3 text-center">
                <img src="~/images/@item.PhotoId"
                     class="img-fluid rounded"
                     alt="@item.Title"
                     style="max-height:150px;" />
            </div>

            <!-- Story Content -->
            <div class="col-md-6">

                <h4>@item.Title</h4>

                <p class="text-muted">
                    Adopted: @item.DatePublished.ToString("MMMM yyyy")
                </p>

                <p class ="story-content clamp">
                    @(item.Content.Length > 150
                                    ? item.Content.Substring(0, 150) + "..."
                                    : item.Content)
            </p>

                <p>
                    <strong>Animal:</strong> @item.Animal?.AnimalType
                </p>

            </div>

            <!-- Read Story Button -->
            <div class="col-md-2 text-end">

                <a asp-action="Details"
                   asp-route-id="@item.StoryId"
                   class="btn btn-outline-primary mb-2">
                    Read Full Story →
                </a>

                <div>
                    <a asp-action="Edit" asp-route-id="@item.StoryId">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.StoryId">Delete</a>
                </div>

            </div>

        </div>
        }

</div>

<div class="text-center mt-4">
    <p>Want to create your own success story?</p>

    <a asp-controller="Animals"
       asp-action="Index"
       class="btn btn-secondary">
        View Available Animals
    </a>
</div>