@model WindysLanding.Controllers.UserViewModel
@{
    ViewData["Title"] = "User Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>User Details</h1>
        <div>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.FullName</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">
                    <a href="mailto:@Model.Email">@Model.Email</a>
                </dd>

                <dt class="col-sm-3">Newsletter Status</dt>
                <dd class="col-sm-9">
                    @if (Model.NewsletterOptIn)
                    {
                        <span class="badge bg-success">✓ Subscribed to Newsletter</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">✗ Not Subscribed</span>
                    }
                </dd>

                <dt class="col-sm-3">Role</dt>
                <dd class="col-sm-9">
                    @if (Model.IsAdmin)
                    {
                        <span class="badge bg-primary">Administrator</span>
                    }
                    else
                    {
                        <span class="badge bg-light text-dark">User</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="mt-4">
        <h4>Actions</h4>
        
        <div class="btn-group" role="group">
            <form asp-action="ToggleNewsletter" asp-route-id="@Model.Id" method="post" class="d-inline">
                <button type="submit" class="btn @(Model.NewsletterOptIn ? "btn-warning" : "btn-success")">
                    @if (Model.NewsletterOptIn)
                    {
                        <text>Unsubscribe from Newsletter</text>
                    }
                    else
                    {
                        <text>Subscribe to Newsletter</text>
                    }
                </button>
            </form>

            <form asp-action="ToggleAdmin" asp-route-id="@Model.Id" method="post" class="d-inline ms-2">
                <button type="submit" 
                        class="btn @(Model.IsAdmin ? "btn-danger" : "btn-primary")"
                        onclick="return confirm('Are you sure you want to @(Model.IsAdmin ? "remove admin access from" : "grant admin access to") @Model.FullName?');">
                    @if (Model.IsAdmin)
                    {
                        <text>Remove Admin Role</text>
                    }
                    else
                    {
                        <text>Grant Admin Role</text>
                    }
                </button>
            </form>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>
