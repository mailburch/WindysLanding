@model IEnumerable<WindysLanding.Controllers.UserViewModel>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="container mt-4">
    <h1 class="mb-4">Manage Users</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <p class="mb-0">No registered users yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th class="text-center">Newsletter</th>
                        <th class="text-center">Admin</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="align-middle">
                                <strong>@user.FullName</strong>
                            </td>
                            <td class="align-middle">
                                <a href="mailto:@user.Email">@user.Email</a>
                            </td>
                            <td class="align-middle text-center">
                                @if (user.NewsletterOptIn)
                                {
                                    <span class="badge bg-success">✓ Subscribed</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">✗ Not Subscribed</span>
                                }
                            </td>
                            <td class="align-middle text-center">
                                @if (user.IsAdmin)
                                {
                                    <span class="badge bg-primary">Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark">User</span>
                                }
                            </td>
                            <td class="align-middle text-center">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="Details" asp-route-id="@user.Id" 
                                       class="btn btn-outline-info">
                                        Details
                                    </a>
                                    
                                    <form asp-action="ToggleNewsletter" asp-route-id="@user.Id" 
                                          method="post" class="d-inline">
                                        <button type="submit" 
                                                class="btn btn-outline-secondary"
                                                title="Toggle Newsletter Subscription">
                                            @if (user.NewsletterOptIn)
                                            {
                                                <text>Unsubscribe</text>
                                            }
                                            else
                                            {
                                                <text>Subscribe</text>
                                            }
                                        </button>
                                    </form>

                                    <form asp-action="ToggleAdmin" asp-route-id="@user.Id" 
                                          method="post" class="d-inline">
                                        <button type="submit" 
                                                class="btn @(user.IsAdmin ? "btn-outline-danger" : "btn-outline-primary")"
                                                onclick="return confirm('Are you sure you want to @(user.IsAdmin ? "remove admin access from" : "grant admin access to") @user.FullName?');">
                                            @if (user.IsAdmin)
                                            {
                                                <text>Remove Admin</text>
                                            }
                                            else
                                            {
                                                <text>Make Admin</text>
                                            }
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                <strong>Total Users:</strong> @Model.Count() 
                <span class="ms-3">
                    <strong>Newsletter Subscribers:</strong> @Model.Count(u => u.NewsletterOptIn)
                </span>
                <span class="ms-3">
                    <strong>Admins:</strong> @Model.Count(u => u.IsAdmin)
                </span>
            </p>
        </div>
    }

    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Home</a>
    </div>
</div>
