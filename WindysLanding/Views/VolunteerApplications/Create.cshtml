@model WindysLanding.Models.VolunteerApplication

@{
    ViewData["Title"] = "Volunteer With Us";
}

<div class="container py-4">

    <!-- Page Header -->
    <div class="text-center mb-4">
        <h1 class="mb-2">Volunteer With Us</h1>
        <p class="text-muted mb-0">
            Help make a difference in the lives of animals in need.
            All volunteers must complete an application and liability waiver.
        </p>
    </div>

    <hr />

    <!-- Volunteer Opportunities -->
    <div class="row justify-content-center">
        <div class="col-md-8">
            <section class="mb-4 p-3">
                <h3 class="h5 text-center">Volunteer Opportunities</h3>
                <ul class="mb-0">
                    <li>Animal care and grooming</li>
                    <li>Facility maintenance and repairs</li>
                    <li>Fundraising events and activities</li>
                    <li>Administrative support</li>
                    <li>Social media and outreach</li>
                </ul>
            </section>
        </div>
    </div>

    <hr />

    <!-- Volunteer Guidelines -->
    <div class="row justify-content-center">
        <div class="col-md-8">
            <section class="mb-4 p-3">
                <h3 class="h5 text-center">Volunteer Guidelines</h3>
                <ul class="mb-0">
                    <li>Volunteers must be screened and approved before starting</li>
                    <li>All volunteers must sign a liability waiver</li>
                    <li>Follow all safety protocols when working with animals</li>
                    <li>Please do not drop in — visits must be scheduled</li>
                </ul>
            </section>
        </div>
    </div>

    <hr />

    <!-- Volunteer Application Form -->
    <div class="text-center mb-3">
        <h2>Volunteer Application</h2>
    </div>

    @* =========================================================
       AUTHENTICATION NOTE
       =========================================================
       For now the form is accessible to everyone so development
       and testing can continue.

       TODO (Google Authentication milestone):
       1. Remove the testing override
       2. Add [Authorize] to the Create GET and POST actions
       3. Prefill Name and Email from Google Auth in GET Create
       4. Overwrite Name and Email from Good AUth in POST Create
    ========================================================= *@

    @{
        bool allowAnonymousTesting = true;
        bool canSubmit = (User?.Identity?.IsAuthenticated ?? false) || allowAnonymousTesting;
    }

    @if (!canSubmit)
    {
        <div class="alert alert-warning text-center">
            <strong>Sign in required.</strong>
            Please sign in with Google to submit a volunteer application.
        </div>

        <div class="text-center">
            <a class="btn btn-dark" href="/Account/Login">Sign in to Continue</a>
        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Name -->
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>

                        @* TODO (Google Auth):
                           - Prefill Name from Google Auth in GET Create()
                           - Overwrite Name in POST Create() from Google Auth
                           - Make readonly when prefilled
                        *@
                        <input asp-for="Name" class="form-control" />

                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>

                        @* TODO (Google Auth):
                           - Prefill Email from Google Auth in GET Create()
                           - Overwrite Email in POST Create() from Google Auth
                        *@
                        <input asp-for="Email" class="form-control" />

                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- Phone -->
                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <!-- Volunteer Description -->
                    <div class="mb-3">
                        <label asp-for="VolunteerDescription" class="form-label"></label>

                        <textarea asp-for="VolunteerDescription"
                                  class="form-control"
                                  rows="5"
                                  placeholder="Tell us why you want to volunteer and any relevant experience."></textarea>

                        <span asp-validation-for="VolunteerDescription" class="text-danger"></span>
                    </div>

                    <!-- Liability Waiver -->
                    <div class="mb-3">
                        <h5 class="mb-2">Liability Waiver</h5>

                        <div class="p-3 bg-light border rounded">
                            <p class="mb-0">
                                Volunteering involves inherent risks including injury from animals,
                                slips and falls, and property damage. By checking the box below,
                                you acknowledge that you understand these risks and agree to follow
                                all safety instructions provided by staff.
                            </p>
                        </div>
                    </div>

                    <!-- Waiver Agreement -->
                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="WaiverSigned" />
                        <label class="form-check-label" asp-for="WaiverSigned">
                            I have read and agree to the liability waiver.
                        </label>

                        <span asp-validation-for="WaiverSigned" class="text-danger"></span>
                    </div>

                    <!-- Submit Buttons -->
                    <div class="d-flex gap-2">
                        <input type="submit" value="Submit Application" class="btn btn-dark" />

                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Back
                        </a>
                    </div>

                    <p class="text-muted mt-3 mb-0">
                        After submitting your application, we will review your information
                        and contact you to schedule an orientation.
                    </p>

                </form>

            </div>
        </div>
    }

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}