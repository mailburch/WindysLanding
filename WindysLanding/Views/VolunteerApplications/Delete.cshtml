@model WindysLanding.Models.VolunteerApplication

@{
    ViewData["Title"] = "Delete Volunteer Application";
}

@* TODO: This page should only be accessible to Admin users once authentication is implemented *@

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

        <div class="text-center mb-4">
            <h1>Delete Volunteer Application</h1>
            <h4 class="text-danger">Are you sure you want to delete this application?</h4>
        </div>

        <div class="card">
            <div class="card-body">

                <dl class="row">

                    <dt class="col-sm-4">
                        @Html.DisplayNameFor(model => model.Name)
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.Name)
                    </dd>

                    <dt class="col-sm-4">
                        @Html.DisplayNameFor(model => model.Email)
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.Email)
                    </dd>

                    <dt class="col-sm-4">
                        @Html.DisplayNameFor(model => model.Phone)
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.Phone)
                    </dd>

                    <dt class="col-sm-4">
                        @Html.DisplayNameFor(model => model.VolunteerDescription)
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.VolunteerDescription)
                    </dd>

                </dl>

            </div>

            <div class="card-footer text-center">

                <form asp-action="Delete">
                    <input type="hidden" asp-for="ApplicationId" />

                    <button type="submit" class="btn btn-danger">
                        Delete Application
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>
                </form>

            </div>

        </div>

    </div>
</div>