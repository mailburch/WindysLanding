@model WindysLanding.Models.VolunteerApplication

@{
    ViewData["Title"] = "Edit Volunteer Application";
}

@* TODO: This page should only be accessible to Admin users once authentication is implemented *@

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

        <div class="text-center mb-4">
            <h1>Edit Volunteer Application</h1>
            <h4 class="text-muted">Update application details</h4>
        </div>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="ApplicationId" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Phone" class="form-label"></label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="VolunteerDescription" class="form-label"></label>
                <textarea asp-for="VolunteerDescription" class="form-control" rows="4"></textarea>
                <span asp-validation-for="VolunteerDescription" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ApplicationDate" class="form-label"></label>
                <input asp-for="ApplicationDate" class="form-control" />
                <span asp-validation-for="ApplicationDate" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="WaiverSigned" />
                <label class="form-check-label" asp-for="WaiverSigned"></label>
            </div>

            <div class="mb-3">
                <label asp-for="WaiverSignedDate" class="form-label"></label>
                <input asp-for="WaiverSignedDate" class="form-control" />
                <span asp-validation-for="WaiverSignedDate" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-center gap-2 mt-4">
                <input type="submit" value="Save Changes" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}